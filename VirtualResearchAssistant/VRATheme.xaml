<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Colors ===== -->
    <Color x:Key="VRA.Bg0">#0F1115</Color>
    <Color x:Key="VRA.Bg1">#161A22</Color>
    <Color x:Key="VRA.Card">#1C2230</Color>
    <Color x:Key="VRA.Stroke">#2A3242</Color>
    <Color x:Key="VRA.Text">#E9EEF5</Color>
    <Color x:Key="VRA.TextDim">#A7B1C2</Color>
    <Color x:Key="VRA.Accent">#7C88FF</Color>
    <Color x:Key="VRA.AccentHover">#9AA3FF</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="VRA.Brush.Bg0" Color="{StaticResource VRA.Bg0}"/>
    <SolidColorBrush x:Key="VRA.Brush.Bg1" Color="{StaticResource VRA.Bg1}"/>
    <SolidColorBrush x:Key="VRA.Brush.Card" Color="{StaticResource VRA.Card}"/>
    <SolidColorBrush x:Key="VRA.Brush.Stroke" Color="{StaticResource VRA.Stroke}"/>
    <SolidColorBrush x:Key="VRA.Brush.Text" Color="{StaticResource VRA.Text}"/>
    <SolidColorBrush x:Key="VRA.Brush.TextDim" Color="{StaticResource VRA.TextDim}"/>
    <SolidColorBrush x:Key="VRA.Brush.Accent" Color="{StaticResource VRA.Accent}"/>
    <SolidColorBrush x:Key="VRA.Brush.AccentHover" Color="{StaticResource VRA.AccentHover}"/>

    <!-- ===== Typography ===== -->
    <FontFamily x:Key="VRA.Font.Primary">Segoe UI</FontFamily>

    <!-- ===== Card (renamed key) ===== -->
    <Style x:Key="VRA.Style.Card" TargetType="Border">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Background" Value="{StaticResource VRA.Brush.Card}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="BorderBrush" Value="{StaticResource VRA.Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ===== TextBox ===== -->
    <Style x:Key="VRA.TextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource VRA.Brush.Text}"/>
        <Setter Property="Background" Value="{StaticResource VRA.Brush.Bg1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VRA.Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontFamily" Value="{StaticResource VRA.Font.Primary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource VRA.Brush.Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Buttons ===== -->
    <!-- Ghost / Secondary -->
    <Style x:Key="VRA.Button.Ghost" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource VRA.Brush.Text}"/>
        <Setter Property="Background" Value="{StaticResource VRA.Brush.Bg1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VRA.Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="FontFamily" Value="{StaticResource VRA.Font.Primary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource VRA.Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary -->
    <Style x:Key="VRA.Button.Primary" TargetType="Button" BasedOn="{StaticResource VRA.Button.Ghost}">
        <Setter Property="Background" Value="{StaticResource VRA.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VRA.Brush.Accent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="10"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource VRA.Brush.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== List styles ===== -->
    <Style x:Key="VRA.ListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource VRA.Brush.Bg1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VRA.Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource VRA.Brush.Text}"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="VRA.ListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource VRA.Brush.Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#28324A"/>
                            <Setter Property="Foreground" Value="{StaticResource VRA.Brush.Text}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource VRA.Brush.Accent}"/>
                            <Setter TargetName="bd" Property="BorderThickness" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#222A3B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
